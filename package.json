{
  "name": "@medram/react-ui-kit",
  "version": "0.1.4",
  "description": "Reusable shadcn/ui component library for React and Next.js applications.",
  "keywords": [
    "react",
    "nextjs",
    "shadcn-ui",
    "tailwindcss",
    "component-library",
    "design-system"
  ],
  "homepage": "https://medram.github.io/react-ui-kit/",
  "bugs": {
    "url": "https://github.com/medram/react-ui-kit/issues"
  },
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/styles/tokens.css",
    "./tailwind": {
      "types": "./dist/tailwind.preset.d.ts",
      "import": "./dist/tailwind.preset.js"
    },
    "./primitives": {
      "types": "./dist/primitives/index.d.ts",
      "import": "./dist/primitives/index.js"
    },
    "./fields": {
      "types": "./dist/fields/index.d.ts",
      "import": "./dist/fields/index.js"
    },
    "./charts": {
      "types": "./dist/charts/index.d.ts",
      "import": "./dist/charts/index.js"
    },
    "./modal": {
      "types": "./dist/modal/index.d.ts",
      "import": "./dist/modal/index.js"
    },
    "./wizard": {
      "types": "./dist/wizard/index.d.ts",
      "import": "./dist/wizard/index.js"
    },
    "./webcam": {
      "types": "./dist/webcam/index.d.ts",
      "import": "./dist/webcam/index.js"
    },
    "./time-picker": {
      "types": "./dist/time-picker/index.d.ts",
      "import": "./dist/time-picker/index.js"
    },
    "./cloud-storage": {
      "types": "./dist/cloud-storage/index.d.ts",
      "import": "./dist/cloud-storage/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@11.10.0",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/medram/react-ui-kit.git"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "docs:build": "vitepress build docs",
    "docs:dev": "vitepress dev docs",
    "docs:preview": "vitepress preview docs",
    "pack:dry": "pnpm pack --dry-run",
    "prepack": "pnpm build",
    "prepublishOnly": "pnpm type:check",
    "type:check": "tsc --noEmit"
  },
  "peerDependencies": {
    "@radix-ui/react-accordion": ">=1.2.0",
    "@radix-ui/react-alert-dialog": ">=1.1.2",
    "@radix-ui/react-avatar": ">=1.0.4",
    "@radix-ui/react-checkbox": ">=1.0.4",
    "@radix-ui/react-collapsible": ">=1.1.1",
    "@radix-ui/react-dialog": ">=1.1.2",
    "@radix-ui/react-dropdown-menu": ">=2.0.6",
    "@radix-ui/react-icons": ">=1.3.0",
    "@radix-ui/react-label": ">=2.0.2",
    "@radix-ui/react-popover": ">=1.0.7",
    "@radix-ui/react-radio-group": ">=1.1.3",
    "@radix-ui/react-scroll-area": ">=1.1.0",
    "@radix-ui/react-select": ">=2.0.0",
    "@radix-ui/react-separator": ">=1.1.0",
    "@radix-ui/react-slot": ">=1.2.4",
    "@radix-ui/react-switch": ">=1.1.0",
    "@radix-ui/react-tabs": ">=1.1.1",
    "@radix-ui/react-tooltip": ">=1.1.3",
    "browser-image-compression": ">=2.0.2",
    "class-variance-authority": ">=0.7",
    "clsx": ">=2",
    "cmdk": ">=1.0.0",
    "date-fns": ">=3.6.0",
    "date-fns-tz": ">=3.2.0",
    "dayjs": ">=1.11.13",
    "formik": ">=2.4.6",
    "framer-motion": ">=11.0.0",
    "lucide-react": ">=0.453.0",
    "next": ">=14",
    "next-themes": ">=0.4.0",
    "pretty-bytes": ">=5.6.0",
    "react": ">=18",
    "react-day-picker": ">=8.10.1",
    "react-dom": ">=18",
    "react-dropzone": ">=14.2.3",
    "react-hot-toast": ">=2.4.1",
    "react-spinners": ">=0.13.8",
    "react-timezone-select": ">=3.2.7",
    "react-webcam": ">=7.2.0",
    "recharts": ">=2.12.7",
    "tailwind-merge": ">=2",
    "tailwind-scrollbar": ">=3",
    "tailwindcss": ">=3",
    "tailwindcss-animate": ">=1.0.7",
    "yup": ">=1.4.0"
  },
